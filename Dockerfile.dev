# syntax=docker/dockerfile:1
# Development image — used by docker-compose for local work.
# Hot-reload via volume mount; no asset precompile, no thruster.

ARG RUBY_VERSION=3.4.8
FROM docker.io/library/ruby:$RUBY_VERSION-slim

WORKDIR /rails

# Install build + runtime deps (kept in one layer since this is a dev image)
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential \
      curl \
      git \
      libpq-dev \
      libyaml-dev \
      pkg-config \
      postgresql-client && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

ENV RAILS_ENV="development" \
    BUNDLE_PATH="/usr/local/bundle"

# Install gems before copying app so this layer is cached across code changes
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy source (will be shadowed by the volume mount in docker-compose)
COPY . .

EXPOSE 3000

# db:prepare runs migrations / loads schema on first boot, then starts Puma
CMD ["bash", "-c", "bin/rails tailwindcss:build && bin/rails db:prepare && bin/rails server -b 0.0.0.0"]
