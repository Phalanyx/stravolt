<%# Hero %>
<div class="max-w-5xl mx-auto px-4 pt-20 pb-12 text-center">
  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-700 mb-6">
    <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
    Live telemetry streaming
  </span>

  <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-5 leading-tight">
    Your Tesla.<br class="hidden sm:block"> Real data. Right now.
  </h1>
  <p class="text-lg text-neutral-500 dark:text-neutral-400 mb-10 max-w-xl mx-auto">
    Connect your Tesla to Stravolt and get live telemetry, automatic trip recording, and a complete picture of every drive — the moment it happens.
  </p>

  <% if user_signed_in? %>
    <%= link_to "Go to Dashboard", dashboard_path,
          class: "inline-flex items-center px-6 py-3 rounded-lg text-sm font-semibold bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
  <% else %>
    <div class="flex items-center justify-center gap-3">
      <%= link_to "Connect your Tesla", new_user_registration_path,
            class: "inline-flex items-center px-6 py-3 rounded-lg text-sm font-semibold bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
      <%= link_to "Sign in", new_user_session_path,
            class: "inline-flex items-center px-6 py-3 rounded-lg text-sm font-semibold border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors" %>
    </div>
  <% end %>
</div>

<%# Stats %>
<div class="border-y border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/50 py-10 mb-16">
  <div class="max-w-5xl mx-auto px-4 grid grid-cols-3 gap-6 text-center">
    <div>
      <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        <div data-controller="animated-number"
             data-animated-number-start-value="0"
             data-animated-number-end-value="100"
             data-animated-number-duration-value="1500"
             data-animated-number-trigger-value="load"
             data-animated-number-suffix-value="ms"></div>
      </div>
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">Streaming interval</p>
    </div>
    <div>
      <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        <div data-controller="animated-number"
             data-animated-number-start-value="0"
             data-animated-number-end-value="30"
             data-animated-number-duration-value="1500"
             data-animated-number-trigger-value="load"
             data-animated-number-suffix-value="+"></div>
      </div>
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">Data points per trip</p>
    </div>
    <div>
      <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        <div data-controller="animated-number"
             data-animated-number-start-value="0"
             data-animated-number-end-value="1"
             data-animated-number-duration-value="800"
             data-animated-number-trigger-value="load"
             data-animated-number-suffix-value=" tap"></div>
      </div>
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">To connect your vehicle</p>
    </div>
  </div>
</div>

<%# Features %>
<div class="max-w-5xl mx-auto px-4 mb-20">
  <h2 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 text-center mb-2">Everything streaming, nothing missed</h2>
  <p class="text-sm text-neutral-500 dark:text-neutral-400 text-center mb-10">From the moment you drive to the moment you park.</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    <%# Feature 1 %>
    <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-6">
      <div class="w-8 h-8 shrink-0 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-neutral-700 dark:text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Live vehicle data</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">Speed, state of charge, power output, location, and dozens more signals — streamed directly from your car in real time.</p>
    </div>

    <%# Feature 2 %>
    <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-6">
      <div class="w-8 h-8 shrink-0 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-neutral-700 dark:text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Automatic trip recording</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">Every drive is captured automatically — start, end, distance, energy used, and a full timeline of the route.</p>
    </div>

    <%# Feature 3 %>
    <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-6">
      <div class="w-8 h-8 shrink-0 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-neutral-700 dark:text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Route & location history</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">See exactly where you've been, replay routes on a map, and browse your full driving history at any time.</p>
    </div>

    <%# Feature 4 %>
    <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-6">
      <div class="w-8 h-8 shrink-0 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-neutral-700 dark:text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Energy & efficiency</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">Track energy consumption per trip, compare efficiency over time, and understand how you actually use your battery.</p>
    </div>

    <%# Feature 5 %>
    <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-6">
      <div class="w-8 h-8 shrink-0 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-neutral-700 dark:text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Dashboard at a glance</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">A clean, real-time dashboard showing your vehicle's current state — charging status, range, location, and more.</p>
    </div>

    <%# Feature 6 %>
    <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-6">
      <div class="w-8 h-8 shrink-0 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-neutral-700 dark:text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Official Tesla Fleet API</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">Connects via Tesla's official Fleet API with OAuth 2.0 — no credentials stored, no unofficial hacks.</p>
    </div>
  </div>
</div>

<%# How it works %>
<div class="max-w-5xl mx-auto px-4 mb-20">
  <div class="bg-white dark:bg-neutral-900 rounded-2xl border border-neutral-200 dark:border-neutral-800 p-10">
    <h2 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-2 text-center">Up and running in minutes</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 text-center mb-10">No configuration. No API keys to manage. Just connect and go.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="flex flex-col items-start">
        <span class="text-xs font-mono font-bold text-neutral-400 dark:text-neutral-500 mb-3">01</span>
        <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Create an account</h3>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">Sign up with your email and you're ready to connect your first vehicle.</p>
      </div>
      <div class="flex flex-col items-start">
        <span class="text-xs font-mono font-bold text-neutral-400 dark:text-neutral-500 mb-3">02</span>
        <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Authorize via Tesla</h3>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">You'll be redirected to Tesla's login page to approve access. We never see your Tesla password.</p>
      </div>
      <div class="flex flex-col items-start">
        <span class="text-xs font-mono font-bold text-neutral-400 dark:text-neutral-500 mb-3">03</span>
        <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Watch the data flow</h3>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">Your dashboard comes alive with live telemetry. Drive anywhere — Stravolt records every second of it.</p>
      </div>
    </div>
  </div>
</div>

<%# CTA %>
<% unless user_signed_in? %>
  <div class="max-w-5xl mx-auto px-4 pb-24 text-center">
    <h2 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-3">Ready to see your Tesla's data?</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-8">Connect in under a minute. No credit card required.</p>
    <%= link_to "Get started for free", new_user_registration_path,
          class: "inline-flex items-center px-6 py-3 rounded-lg text-sm font-semibold bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
  </div>
<% end %>
