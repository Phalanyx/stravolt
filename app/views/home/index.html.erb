<div class="max-w-4xl mx-auto">
  <div class="text-center py-12">
    <h1 class="text-5xl font-bold text-gray-900 mb-4">
      Stravolt
    </h1>
    <p class="text-xl text-gray-600 mb-8">
      Connect your Tesla and unlock powerful fleet management features
    </p>

    <% if user_signed_in? %>
      <%= link_to "Go to Dashboard", dashboard_path, class: "inline-block bg-blue-600 text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-blue-700 transition" %>
    <% else %>
      <div class="space-x-4">
        <%= link_to "Sign Up", new_user_registration_path, class: "inline-block bg-blue-600 text-white px-8 py-3 rounded-lg text-lg font-semibold hover:bg-blue-700 transition" %>
        <%= link_to "Sign In", new_user_session_path, class: "inline-block bg-gray-200 text-gray-800 px-8 py-3 rounded-lg text-lg font-semibold hover:bg-gray-300 transition" %>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
    <div class="bg-white p-6 rounded-lg shadow-sm">
      <h3 class="text-xl font-semibold text-gray-900 mb-2">Secure OAuth</h3>
      <p class="text-gray-600">Authenticate safely with Tesla's official Fleet API using OAuth 2.0</p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow-sm">
      <h3 class="text-xl font-semibold text-gray-900 mb-2">Encrypted Storage</h3>
      <p class="text-gray-600">Your credentials are encrypted using Rails 8's built-in encryption</p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow-sm">
      <h3 class="text-xl font-semibold text-gray-900 mb-2">Virtual Key</h3>
      <p class="text-gray-600">Seamless virtual key pairing with your Tesla vehicles</p>
    </div>
  </div>
</div>
