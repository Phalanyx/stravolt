<div class="max-w-5xl mx-auto px-4 py-16">
  <%# Hero %>
  <div class="text-center py-16">
    <h1 class="text-5xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-4">
      Stravolt
    </h1>
    <p class="text-lg text-neutral-500 dark:text-neutral-400 mb-10 max-w-lg mx-auto">
      Connect your Tesla and unlock powerful fleet management — live data, trips, and telemetry streaming.
    </p>

    <% if user_signed_in? %>
      <%= link_to "Go to Dashboard", dashboard_path,
            class: "inline-flex items-center px-6 py-3 rounded-lg text-sm font-semibold bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
    <% else %>
      <div class="flex items-center justify-center gap-3">
        <%= link_to "Get started", new_user_registration_path,
              class: "inline-flex items-center px-6 py-3 rounded-lg text-sm font-semibold bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
        <%= link_to "Sign in", new_user_session_path,
              class: "inline-flex items-center px-6 py-3 rounded-lg text-sm font-semibold border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors" %>
      </div>
    <% end %>
  </div>

  <%# Feature cards %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
    <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-6">
      <div class="w-8 h-8 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-neutral-700 dark:text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Secure OAuth</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">Authenticate safely with Tesla's official Fleet API using OAuth 2.0.</p>
    </div>

    <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-6">
      <div class="w-8 h-8 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-neutral-700 dark:text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Encrypted Storage</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">Your credentials are stored securely with industry-standard encryption.</p>
    </div>

    <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-6">
      <div class="w-8 h-8 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-neutral-700 dark:text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Live Telemetry</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">Real-time streaming telemetry data with trip recording and interval tracking.</p>
    </div>
  </div>
</div>
