<div class="max-w-5xl mx-auto">
  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">
        <%= @vehicle.display_name || 'Tesla' %>
      </h1>
      <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5 font-mono"><%= @vehicle.vin %></p>
      <% if @vehicle.updated_at %>
        <p class="text-xs text-neutral-400 dark:text-neutral-500 mt-0.5">
          Updated <%= time_ago_in_words(@vehicle.updated_at) %> ago
        </p>
      <% end %>
    </div>
    <div class="flex gap-2">
      <%= link_to "All Vehicles", vehicles_path,
            class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-900 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors" %>
      <%= button_to "Refresh", refresh_vehicle_path(@vehicle), method: :post,
            class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
    </div>
  </div>

  <%# Telemetry card %>
  <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-5 mb-4">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-xs font-semibold text-neutral-500 dark:text-neutral-400 uppercase tracking-wider mb-1">Telemetry Streaming</h2>
        <% if @vehicle.telemetry_active %>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-green-700 dark:text-green-400">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            <%= @vehicle.telemetry_status %>
          </span>
        <% else %>
          <span class="text-sm text-neutral-500 dark:text-neutral-400">Inactive</span>
        <% end %>
        <% if @vehicle.telemetry_configured_at %>
          <p class="text-xs text-neutral-400 dark:text-neutral-500 mt-1">
            Configured <%= time_ago_in_words(@vehicle.telemetry_configured_at) %> ago
          </p>
        <% end %>
      </div>

      <div class="flex gap-2">
        <%= link_to "Check Errors", errors_vehicle_telemetry_path(@vehicle),
              class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-900 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors" %>

        <% if @vehicle.telemetry_active %>
          <div data-controller="modal">
            <button data-action="click->modal#open"
                    class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-red-600 text-white hover:bg-red-700 transition-colors">
              Stop Telemetry
            </button>
            <dialog class="modal rounded-xl p-0" data-modal-target="dialog" data-action="click->modal#backdropClose">
              <div class="bg-white dark:bg-neutral-900 rounded-xl p-6 w-full max-w-sm">
                <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-2">Stop Telemetry?</h3>
                <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-5">This will stop the telemetry stream for this vehicle.</p>
                <div class="flex gap-2 justify-end">
                  <button data-action="click->modal#close"
                          class="px-3 py-1.5 rounded-lg text-sm font-medium border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-900 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors">
                    Cancel
                  </button>
                  <%= button_to "Stop Telemetry", vehicle_telemetry_path(@vehicle), method: :delete,
                        class: "px-3 py-1.5 rounded-lg text-sm font-medium bg-red-600 text-white hover:bg-red-700 transition-colors" %>
                </div>
              </div>
            </dialog>
          </div>
        <% else %>
          <%= button_to "Start Telemetry", vehicle_telemetry_path(@vehicle), method: :post,
                class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
        <% end %>
      </div>
    </div>

    <% if @vehicle.telemetry_config %>
      <div class="mt-4 pt-4 border-t border-neutral-200 dark:border-neutral-800">
        <p class="text-xs text-neutral-500 dark:text-neutral-400">
          Streaming to: <span class="font-mono"><%= @vehicle.telemetry_config['hostname'] %>:<%= @vehicle.telemetry_config['port'] %></span>
        </p>
      </div>
    <% end %>
  </div>

  <%# Recent trips %>
  <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 overflow-hidden mb-4">
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-200 dark:border-neutral-800">
      <h2 class="text-xs font-semibold text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Recent Trips</h2>
      <%= link_to "View All", vehicle_trips_path(@vehicle),
            class: "text-xs font-medium text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors" %>
    </div>

    <% if @recent_trips.any? %>
      <table class="min-w-full divide-y divide-neutral-200 dark:divide-neutral-800">
        <thead class="bg-neutral-50 dark:bg-neutral-950">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Date</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Duration</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Distance</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Battery</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Status</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-200 dark:divide-neutral-800">
          <% @recent_trips.each do |trip| %>
            <tr class="bg-white dark:bg-neutral-950 hover:bg-neutral-50 dark:hover:bg-neutral-900 transition-colors">
              <td class="px-5 py-3 text-sm text-neutral-900 dark:text-neutral-100 whitespace-nowrap">
                <%= trip.started_at.strftime("%b %-d, %Y %H:%M") %>
              </td>
              <td class="px-5 py-3 text-sm text-neutral-500 dark:text-neutral-400 whitespace-nowrap">
                <%= trip.duration_formatted || '—' %>
              </td>
              <td class="px-5 py-3 text-sm text-neutral-500 dark:text-neutral-400 whitespace-nowrap">
                <%= trip.distance_km.present? ? ("%.2f km" % trip.distance_km) : '—' %>
              </td>
              <td class="px-5 py-3 text-sm text-neutral-500 dark:text-neutral-400 whitespace-nowrap">
                <%= trip.battery_consumed_percent.present? ? ("%.1f%%" % trip.battery_consumed_percent) : '—' %>
              </td>
              <td class="px-5 py-3 whitespace-nowrap">
                <% if trip.trip_status == 'completed' %>
                  <span class="inline-flex items-center rounded-full bg-green-50 dark:bg-green-900/20 px-2 py-0.5 text-xs font-medium text-green-700 dark:text-green-400 ring-1 ring-inset ring-green-600/20 dark:ring-green-500/30">Completed</span>
                <% else %>
                  <span class="inline-flex items-center rounded-full bg-amber-50 dark:bg-amber-900/20 px-2 py-0.5 text-xs font-medium text-amber-700 dark:text-amber-400 ring-1 ring-inset ring-amber-600/20 dark:ring-amber-500/30">In Progress</span>
                <% end %>
              </td>
              <td class="px-5 py-3 text-right whitespace-nowrap">
                <%= link_to "View", vehicle_trip_path(@vehicle, trip),
                      class: "text-xs font-medium text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-5 py-10 text-center">
        <p class="text-sm text-neutral-500 dark:text-neutral-400">No trips recorded yet.</p>
      </div>
    <% end %>
  </div>

  <%# Vehicle stats %>
  <% if @vehicle_data.present? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%= render 'dashboard/battery_card', vehicle_data: @vehicle_data %>
      <%= render 'dashboard/location_card', vehicle_data: @vehicle_data %>
      <%= render 'dashboard/vehicle_state_card', vehicle_data: @vehicle_data, vehicle_name: @vehicle.display_name %>
      <% if @vehicle_data.dig('charge_state', 'charging_state') == 'Charging' %>
        <%= render 'dashboard/charging_card', vehicle_data: @vehicle_data %>
      <% end %>
    </div>
  <% end %>
</div>
