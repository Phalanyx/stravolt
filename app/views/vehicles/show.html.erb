<div class="max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-4xl font-bold text-gray-900">
        <%= @vehicle.display_name || 'Tesla' %>
      </h1>
      <p class="text-sm text-gray-600 mt-1">
        VIN: <%= @vehicle.vin %>
      </p>
      <% if @vehicle.updated_at %>
        <p class="text-xs text-gray-500 mt-1">
          Data updated <%= time_ago_in_words(@vehicle.updated_at) %> ago
        </p>
      <% end %>
    </div>
    <div class="flex gap-3">
      <%= link_to "Back to Vehicles", vehicles_path,
                  class: "bg-gray-600 text-white px-4 py-2 rounded-md hover:bg-gray-700" %>
      <%= link_to "View Trips", vehicle_trips_path(@vehicle),
                  class: "bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700" %>
      <%= button_to "Refresh Data", refresh_vehicle_path(@vehicle),
                  method: :post,
                  class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
    </div>
  </div>

  <% if notice %>
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
      <p class="text-sm text-green-800"><%= notice %></p>
    </div>
  <% end %>

  <% if alert %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
      <p class="text-sm text-yellow-800"><%= alert %></p>
    </div>
  <% end %>

  <!-- Telemetry Controls Card -->
  <div class="bg-white rounded-lg shadow-sm p-6 mb-6 border border-gray-200">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Telemetry Streaming</h2>

    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-600">Current Status</p>
        <p class="text-lg font-semibold mt-1">
          <% if @vehicle.telemetry_active %>
            <span class="text-green-600">
              <%= @vehicle.telemetry_status %>
            </span>
          <% else %>
            <span class="text-gray-600">Inactive</span>
          <% end %>
        </p>
        <% if @vehicle.telemetry_configured_at %>
          <p class="text-xs text-gray-500 mt-1">
            Configured <%= time_ago_in_words(@vehicle.telemetry_configured_at) %> ago
          </p>
        <% end %>
      </div>

      <div class="flex gap-3">
        <%= link_to "Check Errors", errors_vehicle_telemetry_path(@vehicle),
                    class: "bg-orange-600 text-white px-4 py-2 rounded-md hover:bg-orange-700 font-medium" %>
        <% if @vehicle.telemetry_active %>
          <%= button_to "Stop Telemetry", vehicle_telemetry_path(@vehicle),
                        method: :delete,
                        data: { confirm: "Are you sure you want to stop telemetry streaming?" },
                        class: "bg-red-600 text-white px-6 py-2 rounded-md hover:bg-red-700 font-medium" %>
        <% else %>
          <%= button_to "Start Telemetry", vehicle_telemetry_path(@vehicle),
                        method: :post,
                        class: "bg-green-600 text-white px-6 py-2 rounded-md hover:bg-green-700 font-medium" %>
        <% end %>
      </div>
    </div>

    <% if @vehicle.telemetry_config %>
      <div class="mt-4 pt-4 border-t border-gray-200">
        <p class="text-xs text-gray-600">
          Streaming to: <%= @vehicle.telemetry_config['hostname'] %>:<%= @vehicle.telemetry_config['port'] %>
        </p>
      </div>
    <% end %>
  </div>

  <!-- Recent Trips -->
  <div class="bg-white rounded-lg shadow-sm p-6 mb-6 border border-gray-200">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-gray-900">Recent Trips</h2>
      <%= link_to "View All Trips", vehicle_trips_path(@vehicle),
          class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
    </div>

    <% if @recent_trips.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Duration</th>
            <th class="py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Distance</th>
            <th class="py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Battery Used</th>
            <th class="py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="py-2"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @recent_trips.each do |trip| %>
            <tr class="hover:bg-gray-50">
              <td class="py-3 text-sm text-gray-900"><%= trip.started_at.strftime("%b %-d, %Y %H:%M") %></td>
              <td class="py-3 text-sm text-gray-600"><%= trip.duration_formatted || '—' %></td>
              <td class="py-3 text-sm text-gray-600">
                <%= trip.distance_km.present? ? ("%.2f km" % trip.distance_km) : '—' %>
              </td>
              <td class="py-3 text-sm text-gray-600">
                <%= trip.battery_consumed_percent.present? ? ("%.1f%%" % trip.battery_consumed_percent) : '—' %>
              </td>
              <td class="py-3">
                <% if trip.trip_status == 'completed' %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Completed</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">In Progress</span>
                <% end %>
              </td>
              <td class="py-3 text-right">
                <%= link_to "View", vehicle_trip_path(@vehicle, trip),
                    class: "text-sm text-indigo-600 hover:text-indigo-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500">No trips recorded yet.</p>
    <% end %>
  </div>

  <!-- Vehicle Stats -->
  <% if @vehicle_data.present? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <%= render 'dashboard/battery_card', vehicle_data: @vehicle_data %>
      <%= render 'dashboard/location_card', vehicle_data: @vehicle_data %>
      <%= render 'dashboard/vehicle_state_card', vehicle_data: @vehicle_data, vehicle_name: @vehicle.display_name %>
      <% if @vehicle_data.dig('charge_state', 'charging_state') == 'Charging' %>
        <%= render 'dashboard/charging_card', vehicle_data: @vehicle_data %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-12 text-center">
      <p class="text-gray-600">No vehicle data available. Click "Refresh Data" to fetch the latest information.</p>
    </div>
  <% end %>
</div>
