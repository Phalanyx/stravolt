<div class="max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-4xl font-bold text-gray-900">
        <%= @vehicle.display_name || 'Tesla' %>
      </h1>
      <p class="text-sm text-gray-600 mt-1">
        VIN: <%= @vehicle.vin %>
      </p>
      <% if @vehicle.updated_at %>
        <p class="text-xs text-gray-500 mt-1">
          Data updated <%= time_ago_in_words(@vehicle.updated_at) %> ago
        </p>
      <% end %>
    </div>
    <div class="flex gap-3">
      <%= link_to "Back to Vehicles", vehicles_path,
                  class: "bg-gray-600 text-white px-4 py-2 rounded-md hover:bg-gray-700" %>
      <%= link_to "Refresh Data", refresh_vehicle_path(@vehicle), method: :post,
                  class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
    </div>
  </div>

  <% if notice %>
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
      <p class="text-sm text-green-800"><%= notice %></p>
    </div>
  <% end %>

  <% if alert %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
      <p class="text-sm text-yellow-800"><%= alert %></p>
    </div>
  <% end %>

  <!-- Telemetry Controls Card -->
  <div class="bg-white rounded-lg shadow-sm p-6 mb-6 border border-gray-200">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Telemetry Streaming</h2>

    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-600">Current Status</p>
        <p class="text-lg font-semibold mt-1">
          <% if @vehicle.telemetry_active %>
            <span class="text-green-600">
              <%= @vehicle.telemetry_status %>
            </span>
          <% else %>
            <span class="text-gray-600">Inactive</span>
          <% end %>
        </p>
        <% if @vehicle.telemetry_configured_at %>
          <p class="text-xs text-gray-500 mt-1">
            Configured <%= time_ago_in_words(@vehicle.telemetry_configured_at) %> ago
          </p>
        <% end %>
      </div>

      <div class="flex gap-3">
        <%= link_to "Check Errors", telemetry_errors_vehicles_path,
                    class: "bg-orange-600 text-white px-4 py-2 rounded-md hover:bg-orange-700 font-medium" %>
        <% if @vehicle.telemetry_active %>
          <%= button_to "Stop Telemetry", stop_telemetry_vehicle_path(@vehicle),
                        method: :post,
                        data: { confirm: "Are you sure you want to stop telemetry streaming?" },
                        class: "bg-red-600 text-white px-6 py-2 rounded-md hover:bg-red-700 font-medium" %>
        <% else %>
          <%= button_to "Start Telemetry", start_telemetry_vehicle_path(@vehicle),
                        method: :post,
                        class: "bg-green-600 text-white px-6 py-2 rounded-md hover:bg-green-700 font-medium" %>
        <% end %>
      </div>
    </div>

    <% if @vehicle.telemetry_config %>
      <div class="mt-4 pt-4 border-t border-gray-200">
        <p class="text-xs text-gray-600">
          Streaming to: <%= @vehicle.telemetry_config['hostname'] %>:<%= @vehicle.telemetry_config['port'] %>
        </p>
      </div>
    <% end %>
  </div>

  <!-- Vehicle Stats -->
  <% if @vehicle_data.present? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <%= render 'dashboard/battery_card', vehicle_data: @vehicle_data %>
      <%= render 'dashboard/location_card', vehicle_data: @vehicle_data %>
      <%= render 'dashboard/vehicle_state_card', vehicle_data: @vehicle_data, vehicle_name: @vehicle.display_name %>
      <% if @vehicle_data.dig('charge_state', 'charging_state') == 'Charging' %>
        <%= render 'dashboard/charging_card', vehicle_data: @vehicle_data %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-12 text-center">
      <p class="text-gray-600">No vehicle data available. Click "Refresh Data" to fetch the latest information.</p>
    </div>
  <% end %>
</div>
