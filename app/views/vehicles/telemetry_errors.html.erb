<div class="max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-4xl font-bold text-gray-900">Telemetry Errors</h1>
    <%= link_to "Back to Vehicles", vehicles_path,
                class: "bg-gray-600 text-white px-4 py-2 rounded-md hover:bg-gray-700" %>
  </div>

  <% if @vehicles.empty? %>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-12 text-center">
      <h3 class="mt-2 text-sm font-semibold text-gray-900">No vehicles found</h3>
      <p class="mt-1 text-sm text-gray-500">Add vehicles to check for telemetry errors.</p>
    </div>
  <% else %>
    <% total_errors = 0 %>
    <% @vehicles.each do |vehicle| %>
      <div class="bg-white rounded-lg shadow-sm p-6 mb-6 border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">
          <%= vehicle.display_name || 'Tesla' %>
          <span class="text-sm text-gray-600 font-normal ml-2">(<%= vehicle.vin %>)</span>
        </h2>

        <% vehicle_errors = @errors_by_vehicle[vehicle.id] %>

        <% if vehicle_errors&.dig('error') %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <p class="text-sm text-red-800">Error fetching data: <%= vehicle_errors['error'] %></p>
          </div>
        <% elsif vehicle_errors&.dig('response', 'errors')&.any? %>
          <% vehicle_errors.dig('response', 'errors').each do |error| %>
            <% total_errors += 1 %>
            <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-3">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <p class="text-sm font-medium text-gray-900">Error Type</p>
                  <p class="mt-1 text-sm text-gray-700"><%= error['error_type'] || 'Unknown' %></p>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900">Timestamp</p>
                  <p class="mt-1 text-sm text-gray-700">
                    <%= error['created_at'] ? Time.parse(error['created_at']).strftime('%Y-%m-%d %H:%M:%S UTC') : 'N/A' %>
                  </p>
                </div>
                <% if error['message'] %>
                  <div class="md:col-span-2">
                    <p class="text-sm font-medium text-gray-900">Message</p>
                    <p class="mt-1 text-sm text-gray-700"><%= error['message'] %></p>
                  </div>
                <% end %>
              </div>
              <% if error['details'] %>
                <div class="mt-4">
                  <p class="text-sm font-medium text-gray-900">Details</p>
                  <pre class="mt-1 text-xs text-gray-700 bg-white p-3 rounded overflow-x-auto"><%= JSON.pretty_generate(error['details']) %></pre>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="bg-green-50 border border-green-200 rounded-lg p-4">
            <div class="flex items-center">
              <svg class="h-5 w-5 text-green-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="ml-3 text-sm text-green-800">No errors found for this vehicle</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if total_errors > 0 %>
      <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-blue-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-blue-700">
              Total errors across all vehicles: <strong><%= total_errors %></strong>
            </p>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="mt-6">
    <%= link_to "Refresh Errors", telemetry_errors_vehicles_path,
                class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 inline-block" %>
  </div>
</div>
