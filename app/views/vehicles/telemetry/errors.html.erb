<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">Telemetry Errors</h1>
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-0.5">
        <%= @vehicle.display_name || 'Tesla' %> &mdash; <span class="font-mono text-xs"><%= @vehicle.vin %></span>
      </p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Refresh", errors_vehicle_telemetry_path(@vehicle),
            class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
      <%= link_to "Back to Vehicle", @vehicle,
            class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-900 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors" %>
    </div>
  </div>

  <% vehicle_errors = @errors&.dig('response', 'errors') %>

  <% if @errors&.dig('error') %>
    <div class="rounded-xl border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-950/30 p-4">
      <p class="text-sm text-red-800 dark:text-red-300">Error fetching data: <%= @errors['error'] %></p>
    </div>

  <% elsif vehicle_errors&.any? %>
    <div class="space-y-3">
      <% vehicle_errors.each do |error| %>
        <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-5">
          <div class="flex items-start justify-between mb-3">
            <span class="inline-flex items-center rounded-full bg-red-50 dark:bg-red-900/20 px-2 py-0.5 text-xs font-medium text-red-700 dark:text-red-400 ring-1 ring-inset ring-red-600/20 dark:ring-red-500/30">
              <%= error['error_type'] || 'Unknown' %>
            </span>
            <span class="text-xs text-neutral-400 dark:text-neutral-500">
              <%= error['created_at'] ? Time.parse(error['created_at']).strftime('%Y-%m-%d %H:%M:%S UTC') : 'N/A' %>
            </span>
          </div>

          <% if error['message'] %>
            <p class="text-sm text-neutral-700 dark:text-neutral-300"><%= error['message'] %></p>
          <% end %>

          <% if error['details'] %>
            <div class="mt-3 pt-3 border-t border-neutral-200 dark:border-neutral-800">
              <p class="text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-2">Details</p>
              <pre class="text-xs text-neutral-600 dark:text-neutral-400 bg-neutral-50 dark:bg-neutral-950 rounded-lg p-3 overflow-x-auto"><%= JSON.pretty_generate(error['details']) %></pre>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="mt-4 rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 px-5 py-3">
      <p class="text-sm text-neutral-600 dark:text-neutral-400">
        Total: <span class="font-semibold text-neutral-900 dark:text-neutral-100"><%= vehicle_errors.size %></span> errors
      </p>
    </div>

  <% else %>
    <div class="rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 p-12 text-center">
      <svg class="mx-auto h-10 w-10 text-green-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-sm font-medium text-neutral-900 dark:text-neutral-100 mb-1">No errors</p>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">No telemetry errors found for this vehicle.</p>
    </div>
  <% end %>
</div>
