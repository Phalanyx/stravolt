<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">My Vehicles</h1>
  </div>

  <% if @vehicles.empty? %>
    <div class="rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 p-12 text-center">
      <svg class="mx-auto h-10 w-10 text-neutral-300 dark:text-neutral-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 17H3a2 2 0 01-2-2V9a2 2 0 012-2h2m14 10h2a2 2 0 002-2V9a2 2 0 00-2-2h-2m-9 8h6m-8-4h10M7 7l2-4h6l2 4"/>
      </svg>
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-1">No vehicles found</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400">Your vehicles will appear here once synced from your Tesla account.</p>
    </div>

  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @vehicles.each do |vehicle| %>
        <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-5 hover:border-neutral-300 dark:hover:border-neutral-700 transition-colors">
          <div class="flex justify-between items-start mb-4">
            <div>
              <h2 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100">
                <%= vehicle.display_name || 'Tesla' %>
              </h2>
              <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5 font-mono">
                <%= vehicle.vin %>
              </p>
            </div>
            <% if vehicle.telemetry_active %>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 dark:bg-green-900/20 px-2 py-0.5 text-xs font-medium text-green-700 dark:text-green-400 ring-1 ring-inset ring-green-600/20 dark:ring-green-500/30">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                Streaming
              </span>
            <% else %>
              <span class="inline-flex items-center rounded-full bg-neutral-100 dark:bg-neutral-800 px-2 py-0.5 text-xs font-medium text-neutral-600 dark:text-neutral-400">
                Inactive
              </span>
            <% end %>
          </div>

          <% if vehicle.battery_level %>
            <div class="mb-4">
              <div class="flex justify-between text-xs mb-1.5">
                <span class="text-neutral-500 dark:text-neutral-400">Battery</span>
                <span class="font-medium text-neutral-900 dark:text-neutral-100"><%= vehicle.battery_level.round %>%</span>
              </div>
              <div class="w-full bg-neutral-100 dark:bg-neutral-800 rounded-full h-1.5">
                <div class="<%= vehicle.battery_level > 20 ? 'bg-neutral-900 dark:bg-neutral-100' : 'bg-red-500' %> h-1.5 rounded-full"
                     style="width: <%= vehicle.battery_level.round %>%"></div>
              </div>
            </div>
          <% end %>

          <%= link_to "View Details", vehicle_path(vehicle),
                class: "block w-full text-center text-sm font-medium px-4 py-2 rounded-lg bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
