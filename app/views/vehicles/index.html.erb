<div class="max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-4xl font-bold text-gray-900">My Vehicles</h1>
    <%= link_to "Back to Dashboard", dashboard_path,
                class: "bg-gray-600 text-white px-4 py-2 rounded-md hover:bg-gray-700" %>
  </div>

  <% if @vehicles.empty? %>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
      </svg>
      <h3 class="mt-2 text-sm font-semibold text-gray-900">No vehicles found</h3>
      <p class="mt-1 text-sm text-gray-500">Your vehicles will appear here once they're synced from your Tesla account.</p>
      <div class="mt-6">
        <%= link_to "Go to Dashboard", dashboard_path,
                    class: "inline-block bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
      </div>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @vehicles.each do |vehicle| %>
        <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200 hover:shadow-md transition-shadow">
          <div class="flex justify-between items-start mb-4">
            <div>
              <h2 class="text-xl font-semibold text-gray-900">
                <%= vehicle.display_name || 'Tesla' %>
              </h2>
              <p class="text-sm text-gray-600 mt-1">
                VIN: <%= vehicle.vin %>
              </p>
            </div>
            <% if vehicle.telemetry_active %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                Streaming
              </span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                Inactive
              </span>
            <% end %>
          </div>

          <% if vehicle.battery_level %>
            <div class="mb-4">
              <div class="flex justify-between text-sm mb-1">
                <span class="text-gray-600">Battery</span>
                <span class="font-semibold text-gray-900"><%= vehicle.battery_level.round %>%</span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-green-500 h-2 rounded-full" style="width: <%= vehicle.battery_level.round %>%"></div>
              </div>
            </div>
          <% end %>

          <div class="mt-4">
            <%= link_to "View Details", vehicle_path(vehicle),
                        class: "block w-full text-center bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
