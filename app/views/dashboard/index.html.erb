<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">Dashboard</h1>
      <% if @vehicle && @vehicle.updated_at %>
        <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-0.5">
          Updated <%= time_ago_in_words(@vehicle.updated_at) %> ago
        </p>
      <% end %>
    </div>
    <% if @vehicle %>
      <div class="flex gap-2">
        <%= link_to "Vehicles", vehicles_path,
              class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-900 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors" %>
        <%= link_to "Refresh", dashboard_path(refresh: true),
              class: "inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
      </div>
    <% end %>
  </div>

  <% if @error %>
    <div class="mb-6 rounded-xl border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-950/30 p-4">
      <div class="flex items-start gap-3">
        <svg class="h-5 w-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <p class="text-sm text-amber-800 dark:text-amber-300"><%= @error %></p>
      </div>
    </div>
  <% end %>

  <% if !current_user.tesla_verified? %>
    <div class="rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 p-6">
      <h3 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100 mb-1">Connect Your Tesla</h3>
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-4">Connect your Tesla account to see live vehicle stats and data.</p>
      <%= link_to "Go to Settings", settings_path,
            class: "inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
    </div>

  <% elsif @vehicle_data %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%= render 'battery_card', vehicle_data: @vehicle_data %>
      <%= render 'location_card', vehicle_data: @vehicle_data %>
      <%= render 'vehicle_state_card', vehicle_data: @vehicle_data, vehicle_name: @vehicle&.display_name %>
      <% if @vehicle_data.dig('charge_state', 'charging_state') == 'Charging' %>
        <%= render 'charging_card', vehicle_data: @vehicle_data %>
      <% end %>
    </div>

  <% elsif @vehicle %>
    <div class="rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 p-12 text-center">
      <p class="text-sm text-neutral-500 dark:text-neutral-400">No vehicle data yet.</p>
      <%= link_to "Refresh Data", dashboard_path(refresh: true),
            class: "mt-4 inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 transition-colors" %>
    </div>
  <% end %>
</div>
