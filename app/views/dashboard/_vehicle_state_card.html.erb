<div class="bg-white rounded-lg shadow-sm p-6">
  <h2 class="text-xl font-semibold text-gray-900 mb-4">Vehicle State</h2>

  <div class="space-y-3">
    <div class="flex justify-between">
      <span class="text-sm text-gray-600">Vehicle Name</span>
      <span class="text-sm font-semibold text-gray-900">
        <%= vehicle_name || 'Tesla' %>
      </span>
    </div>

    <div class="flex justify-between items-center">
      <span class="text-sm text-gray-600">Lock Status</span>
      <% if vehicle_data.dig('vehicle_state', 'locked') %>
        <span class="text-sm font-semibold text-green-600">Locked</span>
      <% else %>
        <span class="text-sm font-semibold text-yellow-600">Unlocked</span>
      <% end %>
    </div>

    <div class="flex justify-between">
      <span class="text-sm text-gray-600">Odometer</span>
      <span class="text-sm font-semibold text-gray-900">
        <%= number_with_delimiter(vehicle_data.dig('vehicle_state', 'odometer')&.round) || 'N/A' %> mi
      </span>
    </div>
  </div>
</div>
