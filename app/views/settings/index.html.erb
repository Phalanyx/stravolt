<div class="max-w-4xl mx-auto">
  <h1 class="text-4xl font-bold text-gray-900 mb-8">Settings</h1>

  <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
    <h2 class="text-2xl font-semibold text-gray-900 mb-4">Account Information</h2>
    <div class="space-y-2">
      <p class="text-gray-600">
        <span class="font-semibold">Email:</span> <%= current_user.email %>
      </p>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
    <h2 class="text-2xl font-semibold text-gray-900 mb-4">Partner Account Registration</h2>
    <p class="text-gray-600 mb-4">
      Before using the Tesla Fleet API, you must register your domain as a partner account.
      This is a one-time setup step.
    </p>

    <%= button_to "Register Partner Account", tesla_partner_register_path,
                  method: :post,
                  class: "bg-purple-600 text-white px-6 py-2 rounded-md hover:bg-purple-700" %>
  </div>

  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-2xl font-semibold text-gray-900 mb-4">Tesla Connection</h2>

    <% if current_user.tesla_connected? %>
      <div class="space-y-4">
        <div class="flex items-center">
          <% if current_user.tesla_verified? %>
            <div class="w-3 h-3 bg-green-500 rounded-full mr-3"></div>
            <span class="text-green-700 font-semibold">Verified with Fleet API</span>
          <% elsif current_user.tesla_started? %>
            <div class="w-3 h-3 bg-yellow-500 rounded-full mr-3"></div>
            <span class="text-yellow-700 font-semibold">OAuth Complete - Needs Fleet API Verification</span>
          <% end %>
        </div>

        <div class="space-y-2 text-gray-600">
          <p>
            <span class="font-semibold">Status:</span>
            <% if current_user.tesla_verified? %>
              <span class="text-green-600">Verified - Ready to use Fleet API</span>
            <% elsif current_user.tesla_started? %>
              <span class="text-yellow-600">Started - Click "Verify with Fleet API" below to complete setup</span>
            <% end %>
          </p>
          <p>
            <span class="font-semibold">Token Status:</span>
            <% if current_user.valid_access_token? %>
              <span class="text-green-600">Valid (expires <%= time_ago_in_words(current_user.token_expires_at) %> from now)</span>
            <% else %>
              <span class="text-yellow-600">Expired (needs refresh)</span>
            <% end %>
          </p>
        </div>

        <div class="flex gap-3 mt-4">
          <% if current_user.tesla_started? %>
            <%= button_to "Verify with Fleet API", tesla_refresh_fleet_token_path,
                          class: "bg-green-600 text-white px-6 py-2 rounded-md hover:bg-green-700" %>
          <% end %>

          <%= button_to "Disconnect Tesla", tesla_disconnect_path, method: :delete,
                        class: "bg-red-600 text-white px-6 py-2 rounded-md hover:bg-red-700",
                        data: { turbo_confirm: "Are you sure you want to disconnect your Tesla account?" } %>
        </div>
      </div>
    <% else %>
      <div class="space-y-4">
        <div class="flex items-center">
          <div class="w-3 h-3 bg-gray-400 rounded-full mr-3"></div>
          <span class="text-gray-600 font-semibold">Not Connected</span>
        </div>

        <p class="text-gray-600">
          Connect your Tesla account to access vehicle data and remote commands.
        </p>

        <%= button_to "Connect Tesla Account", "/auth/tesla",
                      class: "inline-block bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 mt-2",
                      method: :post,
                      data: { turbo: false } %>
      </div>
    <% end %>
  </div>
</div>
